    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "id3": "^0.0.3",
    "postcss": "^8.4.47",
    "sanitize-filename": "^1.6.3",
    "sharp": "^0.33.5",
