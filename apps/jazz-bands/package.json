    "@sanity/client": "^6.23.0",
    "@sanity/color-input": "^6.0.4",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/image-url": "^1.1.0",
    "@sanity/vision": "^5.15.0",
    "@types/howler": "^2.2.12",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "framer-motion": "^12.36.0",
    "howler": "^2.2.4",
    "isbot": "^5.1.0",
    "mongodb": "^6.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
