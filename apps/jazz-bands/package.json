{
  "name": "jazz-bands-ssr",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "npx dotenv-cli -e .env -- react-router dev --host",
    "start": "node ./build/server/index.js",
    "typecheck": "tsc --noEmit",
    "studio:dev": "sanity dev --host 0.0.0.0",
